{
  "name": "agentforge",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist/ out/ pkg/",
    "dev": "concurrently -n backend,frontend -c cyan,magenta \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:frontend": "vite",
    "dev:backend": "bun --hot src/backend/main.ts",
    "build:frontend": "vite build",
    "build:backend": "bun scripts/build.ts",
    "build": "bun run build:frontend && bun run build:backend",
    "build:all": "bun run build:frontend && bun scripts/build.ts all",
    "preview": "vite preview",
    "package": "bun scripts/package.ts",
    "start": "./dist/native/agentforge",
    "typecheck:frontend": "tsc --build src/frontend/tsconfig.json",
    "typecheck:backend": "tsc --build src/backend/tsconfig.json",
    "typecheck:common": "tsc --build src/common/tsconfig.json",
    "typecheck": "tsc --build",
    "check": "oxfmt --check . && oxlint .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepare": "git config core.hooksPath scripts/githooks"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@pierre/diffs": "^1.1.15",
    "@tailwindcss/vite": "^4.2.2",
    "@xterm/addon-attach": "^0.12.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "bun": "1.3.11",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "hono": "^4.12.14",
    "lucide-react": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^7.14.1",
    "simple-git": "^3.36.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.0"
  }
}
