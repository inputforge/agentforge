{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "../../out/common"
  },
  "include": ["."]
}
